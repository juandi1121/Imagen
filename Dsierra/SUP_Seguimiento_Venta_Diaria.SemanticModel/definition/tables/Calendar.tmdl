	column 'Orden Día Semana' = WEEKDAY('Calendar'[Date], 2)
		formatString: 0
		lineageTag: bb320e59-1359-4141-a781-3db9fdda5fa5
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Día Semana' =
			
			SWITCH(
			    TRUE(),
			    'Calendar'[Orden Día Semana] = 1, "Lun",
			    'Calendar'[Orden Día Semana] = 2, "Mar",
			    'Calendar'[Orden Día Semana] = 3, "Mié",
			    'Calendar'[Orden Día Semana] = 4, "Jue",
			    'Calendar'[Orden Día Semana] = 5, "Vie",
			    'Calendar'[Orden Día Semana] = 6, "Sáb",
			    "Dom"
			)
		lineageTag: 3a48ddb8-1bf3-4c26-a108-59fe6ea9e431
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition Calendar = calculated
		mode: import
		source = ```
				
				VAR AnoInicio = 2024
				VAR AnoFin = YEAR(TODAY()) 
				RETURN
				ADDCOLUMNS (
				    CALENDAR (
				        DATE(AnoInicio, 1, 1),
				        DATE(AnoFin, 12, 31)
				    ),
				    "Año", YEAR([Date]),
				    "Mes", FORMAT([Date], "MMMM"),
				    "Mes_Num", MONTH([Date]),
				    "YYYYMM", FORMAT([Date], "YYYYMM"),
				    "Nombre_Mes_Año", FORMAT([Date], "MMM YYYY"),
				    "Inicio_Mes", DATE(YEAR([Date]), MONTH([Date]), 1),
				    "Días del Mes", DAY(EOMONTH([Date], 0))
				)
				```

	annotation PBI_Id = b87d541009164c6897796d7af6623664

