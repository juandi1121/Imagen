	partition TablaRanking = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    SUMMARIZE(
				        'Venta_Diaria',
				        'Centros_Operación'[centroop_id],
				        'Unidades_Negocio'[Nombre_UN],
				        'Calendar'[Date]
				    ),
				    "Venta", CALCULATE([Venta_Diaria]),
				    "Presupuesto", CALCULATE([Presupuesto_Hoy..]),
				    "%Cump", DIVIDE([Venta_Diaria], [Presupuesto Hoy], 0)
				)

	annotation PBI_Id = fc233bc4c838403a8de56e8752930554

